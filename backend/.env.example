# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://nexhire:nexhire123@localhost:5432/nexhire_db"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-64-random-chars-before-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"   # switch to gpt-4o before go-live

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
APP_URL="http://localhost:5173"   # frontend URL (used in invite emails)

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@nexhire.com"

# ─── AWS S3 (optional for v1 — skip until Week 3) ────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""

# ─── Interview ───────────────────────────────────────────────────────────────
INVITE_EXPIRY_DAYS=7
